{
  "device": "/dev/null",
  "baudrate": 9600,
  "refresh_ms": 1000,
  "display": {
    "type": "stdout",
    "cols": 20,
    "rows": 4
  },
  "providers": [
    "cpu",
    "gpu",
    "ram",
    "system",
    "network"
  ],
  "screens": [
    {
      "name": "stdout-preview",
      "interval_ms": 2000,
      "lines": [
        "CPU {bar:cpu.load,6} {cpu.load}%",
        "GPU {bar:gpu.load,6} {gpu.load}%",
        "RAM {ram.percent}% {ram.used_gb}",
        "{system.time} {system.hostname}"
      ]
    }
  ]
}
