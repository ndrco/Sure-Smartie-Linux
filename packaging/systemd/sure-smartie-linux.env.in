# Shared environment for the service and the sleep hook.
#
# Leave SURE_SMARTIE_CONFIG commented if you want the runtime to auto-discover:
# 1. ./configs/sure-example.json (local dev run)
# 2. @CMAKE_INSTALL_FULL_SYSCONFDIR@/sure-smartie-linux/config.json
# 3. @CMAKE_INSTALL_FULL_SYSCONFDIR@/sure-smartie-linux/config.json.example
#
# Uncomment and adjust only if you keep the runtime config elsewhere.
# SURE_SMARTIE_CONFIG=@CMAKE_INSTALL_FULL_SYSCONFDIR@/sure-smartie-linux/config.json
# SURE_SMARTIE_LOG_LEVEL=info
# Optional: explicit Unix socket path used by `--set-screen`.
# Default is /run/sure-smartie-linux/control.sock.
# SURE_SMARTIE_SCREEN_CONTROL_SOCKET=/run/sure-smartie-linux/control.sock
# Legacy alias is still supported:
# SURE_SMARTIE_SCREEN_COMMAND_FILE=/run/sure-smartie-linux/control.sock
#
# Optional: explicitly tell the suspend/resume hook which unit to pause.
# Useful if you run the root variant:
# SURE_SMARTIE_SERVICE_NAME=sure-smartie-linux-root.service
