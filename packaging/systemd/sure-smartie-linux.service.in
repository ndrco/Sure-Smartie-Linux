[Unit]
Description=Sure Smartie Linux LCD service
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
ExecStart=@CMAKE_INSTALL_FULL_BINDIR@/sure-smartie-linux --config @CMAKE_INSTALL_FULL_SYSCONFDIR@/sure-smartie-linux/config.json
Restart=on-failure
RestartSec=2
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
